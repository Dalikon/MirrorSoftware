{
  "name": "smartmirrordisplay",
  "version": "1.0.0",
  "description": "A MagicMirror derivative done as an personal project with new features",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "tsc -p tsconfig.client.json",
    "build": "npm run build:server && npm run build:client",
    "server": "node js/index.js",
    "server:dist": "node dist/js/index.js",
    "mirrorClient": "node_modules/.bin/electron js/electron.js",
    "mirrorClient:dist": "node_modules/.bin/electron dist/js/electron.js"
  },
  "author": "Dalibor Peňas",
  "license": "MIT",
  "dependencies": {
    "electron": "^31.3.1",
    "envsub": "^4.1.0",
    "express": "^4.19.2",
    "express-ipfilter": "^1.3.2",
    "helmet": "^7.1.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
