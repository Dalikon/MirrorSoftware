{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "js/module.ts",
    "js/clientMain.ts",
    "js/clientSocket.ts",
    "js/UserService.ts",
    "js/utils.ts",
    "js/mirror.ts",
    "types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
