{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "skipLibCheck": true
  },
  "include": [
    "js/index.ts",
    "js/server.ts",
    "js/helper.ts",
    "js/clientTracker.ts",
    "js/electron.ts",
    "types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
